# Copy to .env.production and fill in your deployed backend URL before building for device

# Your deployed FastAPI backend
VITE_API_BASE_URL=https://api.your-domain.com

# WebSocket (use wss:// for HTTPS backends)
VITE_WS_BASE_URL=wss://api.your-domain.com

# API key (match API_KEYS in your backend .env)
VITE_API_KEY=your-production-api-key
