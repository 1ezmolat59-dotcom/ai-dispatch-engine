# ═══════════════════════════════════════════════════════════════════
#  AI Dispatch Engine — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_RELOAD=false
LOG_LEVEL=INFO
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:3000,https://yourdashboard.com

# ─── API Authentication ─────────────────────────────────────────────
# Comma-separated list of valid API keys. Leave empty to disable auth
# (useful for local development). All /api/v1/* routes are protected.
# Public paths (always skip auth): /health, /docs, /redoc, /openapi.json, /ws/board
API_KEYS=your-secret-key-here,another-key-if-needed
# REQUIRE_WEBHOOK_SECRET=true   # Reject webhooks without HMAC sig (strict mode)

# ─── Database Persistence ───────────────────────────────────────────
# Default: SQLite in the current directory. Change to PostgreSQL for production.
DATABASE_URL=sqlite+aiosqlite:///./dispatch.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dispatch
DB_ECHO=false             # Set true to log all SQL queries (debug only)

# ─── AI Optimization Engine ────────────────────────────────────────
OPTIMIZATION_INTERVAL=30          # Seconds between optimization cycles
ETA_REFRESH_INTERVAL=120          # Seconds between ETA recalculation
LOCATION_STALE_THRESHOLD=120      # Seconds before GPS is considered stale

# ─── Scoring Weights (must sum to 1.0) ─────────────────────────────
# Default values shown — override to tune dispatch behavior.
WEIGHT_DISTANCE=0.30              # Proximity (biggest factor)
WEIGHT_SKILL=0.30                 # Skill match quality
WEIGHT_WORKLOAD=0.15              # Prefer less busy techs
WEIGHT_PERFORMANCE=0.15           # Rating + on-time rate
WEIGHT_AVAILABILITY=0.10          # How quickly tech can start
# Startup emits a warning if weights don't sum to 1.0 (tolerance ±0.01)

# ─── Priority Bonuses (additive on top of weighted score) ──────────
BONUS_EMERGENCY=0.50
BONUS_URGENT=0.25
BONUS_HIGH=0.10
BONUS_NORMAL=0.0
BONUS_LOW=-0.05
MAX_DISPATCH_DISTANCE_KM=150      # Hard cutoff for tech assignment
MAX_REASONABLE_DISTANCE_KM=80.0   # Penalty threshold for proximity score

# ─── Google Maps API ───────────────────────────────────────────────
# Get key: https://console.cloud.google.com/
# Enable: Distance Matrix API, Directions API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
MAPS_TRAFFIC_MODEL=best_guess     # best_guess | pessimistic | optimistic
MAPS_CACHE_TTL=300                # Cache TTL in seconds
MAPS_CIRCUIT_BREAKER_THRESHOLD=3  # Failures before disabling Maps API
MAPS_CIRCUIT_BREAKER_COOLDOWN=300 # Seconds to wait before retrying

# ─── Apple Maps (optional — deep links only, no server key needed) ─
# For MapKit JS server-side routing, provide these:
APPLE_MAPS_TEAM_ID=
APPLE_MAPS_KEY_ID=
APPLE_MAPS_PRIVATE_KEY_PATH=

# ─── FSM Integration ───────────────────────────────────────────────
# Set FSM_PROVIDER to: servicetitan | jobber | generic | none
FSM_PROVIDER=generic

# Generic REST FSM
FSM_BASE_URL=https://api.yourfsm.com/v1
FSM_API_KEY=your_fsm_api_key_here
FSM_WEBHOOK_SECRET=your_webhook_signing_secret

# ServiceTitan (if FSM_PROVIDER=servicetitan)
ST_CLIENT_ID=
ST_CLIENT_SECRET=
ST_APP_KEY=
ST_TENANT_ID=

# Jobber (if FSM_PROVIDER=jobber)
JOBBER_API_KEY=

# ─── SMS Notifications (Twilio) ────────────────────────────────────
# Get credentials: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567

# ─── Email Notifications ───────────────────────────────────────────
# Option A: SMTP (Gmail, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dispatch@yourcompany.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=dispatch@yourcompany.com
EMAIL_FROM_NAME=Your Service Team

# Option B: SendGrid (takes priority over SMTP if set)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Notification Webhook (optional) ──────────────────────────────
NOTIFICATION_WEBHOOK_URL=https://yourapp.com/dispatch/events
NOTIFICATION_WEBHOOK_SECRET=your_secret_here
NOTIFICATION_RATE_LIMIT=1800      # Seconds between messages to same customer

# ─── Company Info ──────────────────────────────────────────────────
COMPANY_NAME=Your HVAC & Plumbing Co.
COMPANY_PHONE=+15559876543
RATING_BASE_URL=https://yourapp.com

# ─── ML Model ──────────────────────────────────────────────────────
# Changed from /tmp (wiped on Linux restart) to a persistent path
ML_MODEL_PATH=ai_dispatch/data/dispatch_model.pkl
ML_DATA_PATH=ai_dispatch/data/historical_jobs.json
ML_MIN_SAMPLES=50                 # Min records before trusting ML
ML_RETRAIN_INTERVAL=50            # Retrain after every N completions
